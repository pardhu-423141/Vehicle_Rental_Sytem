datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  USER_MANAGER
  VEHICLE_MANAGER
  ADMIN
}

enum KYCStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String
  password String
  role     Role   @default(USER)

  isVerified Boolean   @default(false)
  otp        String?
  otpExpires DateTime?

  passwordResetToken   String?
  passwordResetExpires DateTime?

  kycStatus KYCStatus @default(NOT_SUBMITTED)
  kycData   KYCData?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  reviews   Review[]

  managedVehicles Vehicle[]

  reportedIssues Issue[] @relation("ReportedByAdmin")
  assignedIssues Issue[] @relation("AssignedToManager")

  statusLogs VehicleStatusLog[]
  coupons    UserCoupon[]
}

enum VehicleType {
  TWO_WHEELER
  FOUR_SEATER
  FIVE_SEATER
  SEVEN_SEATER
  LUXURY
}

model Vehicle {
  id           String  @id @default(uuid())
  make         String
  model        String
  year         Int
  licensePlate String  @unique
  color        String
  fuelType     String
  transmission String
  rentalRate   Float
  imageUrl     String?

  type            VehicleType @default(FIVE_SEATER)
  seatingCapacity Int         @default(5)

  status    String    @default("Available")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  bookings Booking[]
  reviews  Review[]

  managerId String?
  manager   User?   @relation(fields: [managerId], references: [id])

  maintenanceTasks  MaintenanceTask[]
  issues            Issue[]
  vehicleStatusLogs VehicleStatusLog[]
}

model Booking {
  id         String        @id @default(uuid())
  userId     String
  vehicleId  String
  startDate  DateTime
  endDate    DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)

  couponId   String?
  couponCode String?
  discount   Float?  @default(0)

  user    User     @relation(fields: [userId], references: [id])
  vehicle Vehicle  @relation(fields: [vehicleId], references: [id])
  payment Payment?

  handoverAt DateTime?
  returnAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review?
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  amount        Float
  paymentMethod String
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique

  booking Booking @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Review {
  id        String  @id @default(uuid())
  rating    Int
  comment   String?
  userId    String
  vehicleId String

  user    User    @relation(fields: [userId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  createdAt DateTime @default(now())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])
}

model KYCData {
  id           String  @id @default(uuid())
  userId       String  @unique
  idType       String
  idNumber     String  @unique
  idImageFront String
  idImageBack  String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceTask {
  id           String   @id @default(uuid())
  issue        String
  status       String   @default("Pending")
  reportedDate DateTime @default(now())

  resolvedAt DateTime?

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
}

enum IssueStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model Issue {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  reportedByAdminId String
  reportedByAdmin   User   @relation("ReportedByAdmin", fields: [reportedByAdminId], references: [id])

  assignedManagerId String
  assignedManager   User   @relation("AssignedToManager", fields: [assignedManagerId], references: [id])

  title       String
  description String
  response    String?

  status IssueStatus @default(OPEN)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model VehicleStatusLog {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  changedBy String
  changer   User   @relation(fields: [changedBy], references: [id])

  status String
  reason String?

  createdAt DateTime @default(now())
}

// ─── COUPON SYSTEM ────────────────────────────────────────────────────────────

enum CouponType {
  WELCOME
  MILESTONE
}

enum DiscountType {
  PERCENT
  FIXED
}

model UserCoupon {
  id     String @id @default(uuid())
  code   String @unique
  userId String
  user   User   @relation(fields: [userId], references: [id])

  couponType    CouponType
  discountType  DiscountType @default(PERCENT)
  discountValue Float // 10 = 10% or ₹10 fixed

  maxDiscount      Float? // cap for PERCENT type (e.g. 200 → max ₹200 off)
  minBookingAmount Float? // minimum booking amount required
  conditions       String? // human-readable conditions text

  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())
}
