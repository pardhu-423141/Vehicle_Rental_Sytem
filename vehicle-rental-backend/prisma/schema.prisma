generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  USER_MANAGER
  VEHICLE_MANAGER
  ADMIN
}

enum KYCStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum VehicleType {
  TWO_WHEELER
  FOUR_SEATER
  FIVE_SEATER
  SEVEN_SEATER
  LUXURY
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  name                 String
  password             String
  phone                String?
  role                 Role               @default(USER)
  isVerified           Boolean            @default(false)
  isActive             Boolean            @default(true)
  otp                  String?
  otpExpires           DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  kycStatus            KYCStatus          @default(NOT_SUBMITTED)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  bookings             Booking[]
  assignedIssues       Issue[]            @relation("AssignedToManager")
  reportedIssues       Issue[]            @relation("ReportedByAdmin")
  kycData              KYCData?
  reviews              Review[]
  managedVehicles      Vehicle[]
  statusLogs           VehicleStatusLog[]
  coupons              UserCoupon[]
}

model Vehicle {
  id                String             @id @default(uuid())
  make              String
  model             String
  year              Int
  licensePlate      String             @unique
  color             String
  fuelType          String
  transmission      String
  rentalRate        Float
  imageUrl          String?
  status            String             @default("Available")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  seatingCapacity   Int                @default(5)
  type              VehicleType        @default(FIVE_SEATER)
  managerId         String?
  bookings          Booking[]
  issues            Issue[]
  maintenanceTasks  MaintenanceTask[]
  reviews           Review[]
  manager           User?              @relation(fields: [managerId], references: [id])
  vehicleStatusLogs VehicleStatusLog[]
}

model Booking {
  id         String        @id @default(uuid())
  userId     String
  vehicleId  String
  startDate  DateTime
  endDate    DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  handoverAt DateTime?
  returnAt   DateTime?
  couponId   String?
  couponCode String?
  discount   Float?        @default(0)
  user       User          @relation(fields: [userId], references: [id])
  vehicle    Vehicle       @relation(fields: [vehicleId], references: [id])
  payment    Payment?
  review     Review?
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  amount        Float
  paymentMethod String
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique
  createdAt     DateTime      @default(now())
  booking       Booking       @relation(fields: [bookingId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  userId    String
  vehicleId String
  createdAt DateTime @default(now())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model KYCData {
  id              String   @id @default(uuid())
  userId          String   @unique
  idType          String
  idNumber        String   @unique
  idImageFront    String
  idImageBack     String?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model MaintenanceTask {
  id           String    @id @default(uuid())
  issue        String
  status       String    @default("Pending")
  reportedDate DateTime  @default(now())
  vehicleId    String
  resolvedAt   DateTime?
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id])
}

enum IssueStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model Issue {
  id                String      @id @default(uuid())
  vehicleId         String
  reportedByAdminId String
  assignedManagerId String
  description       String
  response          String?
  status            IssueStatus @default(OPEN)
  createdAt         DateTime    @default(now())
  resolvedAt        DateTime?
  title             String
  assignedManager   User        @relation("AssignedToManager", fields: [assignedManagerId], references: [id])
  reportedByAdmin   User        @relation("ReportedByAdmin", fields: [reportedByAdminId], references: [id])
  vehicle           Vehicle     @relation(fields: [vehicleId], references: [id])
}

model VehicleStatusLog {
  id        String   @id @default(uuid())
  vehicleId String
  changedBy String
  status    String
  reason    String?
  createdAt DateTime @default(now())
  changer   User     @relation(fields: [changedBy], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

enum CouponType {
  WELCOME
  MILESTONE
}

enum DiscountType {
  PERCENT
  FIXED
}

model UserCoupon {
  id               String    @id @default(uuid())
  code             String    @unique
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  couponType       CouponType
  discountType     DiscountType @default(PERCENT)
  discountValue    Float
  maxDiscount      Float?
  minBookingAmount Float?
  conditions       String?
  isUsed           Boolean   @default(false)
  usedAt           DateTime?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
}
